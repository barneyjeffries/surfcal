# SurfCal environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored and must never be committed.

# Supabase project URL (public, exposed to the browser)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public API key (public, exposed to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (SECRET — server-side only, never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Stormglass API key for waves/wind/tide data (SECRET — server-side only)
STORMGLASS_API_KEY=

# Shared secret guarding the cron refresh route (SECRET — server-side only).
# The refresh endpoint requires `Authorization: Bearer ${CRON_SECRET}`.
# Generate one with: openssl rand -hex 32
CRON_SECRET=
